# Copy to `secrets.env` (gitignored) and fill in, then `make secrets-apply`.
# Generate strong values, e.g.  openssl rand -hex 32
JWT_SECRET=change-me
POSTGRES_PASSWORD=change-me

# --- Optional: prod Postgres backup (U1). Leave blank to skip backups. ---
# These land as OPTIONAL keys in app-secrets (secretKeyRef optional:true), so an
# unset value doesn't wedge any pod — the backup CronJob just fails+alerts until
# configured. MINIO_ENDPOINT is any S3-compatible endpoint (MinIO, R2, S3).
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
# Optional failure alerting for the backup job (Discord webhook URL).
DISCORD_WEBHOOK=
