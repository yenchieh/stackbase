# Prod image: build the static bundle, serve it with nginx. /api is routed by
# the shared Traefik (IngressRoute), not nginx — nginx only serves the SPA.
FROM node:22 AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 5173
